<view class="status-page">
  <view class="hero-card">
    <view class="hero-badge">记</view>
    <view class="hero-title">同步状态</view>
    <view class="hero-desc">查看当前账号最近一次状态更新与近期记录</view>
  </view>

  <view class="summary-card" wx:if="{{!loading}}">
    <view class="summary-row">
      <view class="summary-item">
        <view class="summary-label">当前状态</view>
        <view class="summary-value">{{statusText}}</view>
      </view>
      <view class="summary-item">
        <view class="summary-label">最近结果</view>
        <view class="summary-value">{{lastResultText}}</view>
      </view>
    </view>

    <view class="summary-grid" wx:if="{{hasTask}}">
      <view class="info-chip">
        <view class="chip-label">时间区间</view>
        <view class="chip-value">{{timeRange}}</view>
      </view>
      <view class="info-chip">
        <view class="chip-label">目标进度</view>
        <view class="chip-value">{{currentProgress}}</view>
      </view>
      <view class="info-chip">
        <view class="chip-label">目标步数</view>
        <view class="chip-value">{{targetSteps}}</view>
      </view>
      <view class="info-chip">
        <view class="chip-label">连续重试</view>
        <view class="chip-value">{{consecutiveFailures}}</view>
      </view>
    </view>

    <view class="empty-card" wx:else>
      <view class="empty-title">当前还没有同步安排</view>
      <view class="empty-desc">开启后，这里会展示最近一次状态更新与记录时间</view>
    </view>
  </view>

  <view class="detail-card" wx:if="{{!loading}}">
    <view class="card-title">状态概览</view>
    <view class="detail-row">
      <text class="detail-label">最近一次完成</text>
      <text class="detail-value">{{lastSuccessAt || '暂未完成'}}</text>
    </view>
    <view class="detail-row">
      <text class="detail-label">最近一次尝试</text>
      <text class="detail-value">{{lastAttemptAt || '暂未开始'}}</text>
    </view>
    <view class="detail-row">
      <text class="detail-label">下次状态更新时间</text>
      <text class="detail-value">{{nextSyncAt || '--'}}</text>
    </view>
    <view class="detail-note">{{lastDetail}}</view>
  </view>

  <view class="log-card" wx:if="{{!loading}}">
    <view class="card-title">最近记录</view>
    <view class="log-item" wx:for="{{logs}}" wx:key="index">
      <view class="log-meta">
        <text class="log-status">{{item.status_text}}</text>
        <text class="log-time">{{item.created_at}}</text>
      </view>
      <view class="log-detail">{{item.displayDetail}}</view>
    </view>
    <view class="log-empty" wx:if="{{logs.length === 0}}">最近还没有新的状态记录</view>
  </view>

  <view class="loading-state" wx:if="{{loading}}">状态加载中...</view>
</view>
