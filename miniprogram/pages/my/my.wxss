/* pages/my/my.wxss */

/* ========== 页面基础 ========== */
.page {
  min-height: 100vh;
  padding: 0 24rpx 40rpx;
  background: linear-gradient(180deg, #f0f4ff 0%, #f8fafc 30%, #f5f7fb 100%);
  box-sizing: border-box;
  position: relative;
}

/* 渐变头部背景 */
.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 320rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%);
  border-radius: 0 0 60rpx 60rpx;
  z-index: 0;
}

.header-bg::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.08'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
  border-radius: 0 0 60rpx 60rpx;
}

/* ========== 账户卡片 ========== */
.account-card {
  position: relative;
  z-index: 1;
  margin-top: 60rpx;
  padding: 40rpx 32rpx 32rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 32rpx;
  box-shadow:
    0 8rpx 32rpx rgba(102, 126, 234, 0.15),
    0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  backdrop-filter: blur(20rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 头像区域 */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-picker {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0;
  background: transparent;
  border: none;
  line-height: 1;
}

.avatar-picker::after {
  border: none;
}

.avatar-wrap {
  position: relative;
}

.account-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  position: relative;
  z-index: 2;
}

.account-avatar.fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  font-size: 56rpx;
  font-weight: 700;
}

.avatar-ring {
  position: absolute;
  top: -8rpx;
  left: -8rpx;
  right: -8rpx;
  bottom: -8rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.4);
  z-index: 1;
}

.avatar-edit-tip {
  margin-top: 12rpx;
  padding: 6rpx 16rpx;
  background: rgba(102, 126, 234, 0.1);
  border-radius: 999rpx;
  color: #667eea;
  font-size: 20rpx;
  font-weight: 500;
}

/* 昵称编辑区域 */
.nickname-section {
  margin-top: 24rpx;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.nickname-input {
  text-align: center;
  color: #1a1a2e;
  font-size: 40rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  padding: 12rpx 24rpx;
  border-radius: 16rpx;
  background: transparent;
  transition: all 0.2s ease;
}

.nickname-input:focus {
  background: rgba(102, 126, 234, 0.05);
}

.nickname-placeholder {
  color: #c4cad4;
}

.nickname-hint {
  margin-top: 8rpx;
  color: #9ca3af;
  font-size: 22rpx;
}

/* 登录区域 */
.login-section {
  margin-top: 24rpx;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.login-tip {
  color: #6b7280;
  font-size: 26rpx;
  margin-bottom: 20rpx;
}

.login-btn {
  width: 100%;
  max-width: 400rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  box-shadow: 0 6rpx 20rpx rgba(102, 126, 234, 0.35);
}

/* 状态标签行 */
.status-row {
  margin-top: 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
  justify-content: center;
}

.status-chip {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
  transition: all 0.3s ease;
}

.status-chip.vip {
  background: linear-gradient(135deg, #ffd700 0%, #ffb347 100%);
  color: #7c5800;
  box-shadow: 0 2rpx 8rpx rgba(255, 183, 71, 0.4);
}

.status-chip.default {
  background: rgba(102, 126, 234, 0.1);
  color: #667eea;
}

.status-chip.complete {
  background: rgba(16, 185, 129, 0.1);
  color: #10b981;
}

.status-chip.pending {
  background: rgba(245, 158, 11, 0.1);
  color: #f59e0b;
}

.chip-icon {
  font-size: 20rpx;
}

/* 统计区块 */
.account-stats {
  margin-top: 28rpx;
  width: 100%;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(102, 126, 234, 0.1);
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200rpx, 1fr));
  gap: 16rpx;
}

.stat-block {
  padding: 20rpx 24rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #f8fafc 0%, #f0f4ff 100%);
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.stat-icon {
  font-size: 32rpx;
}

.stat-info {
  flex: 1;
  min-width: 0;
}

.stat-value {
  color: #1a1a2e;
  font-size: 30rpx;
  font-weight: 700;
}

.stat-value.small {
  font-size: 24rpx;
}

.stat-label {
  margin-top: 2rpx;
  color: #9ca3af;
  font-size: 20rpx;
}

/* 保存按钮 */
.save-btn {
  margin-top: 28rpx;
  width: 100%;
  height: 88rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  box-shadow: 0 6rpx 20rpx rgba(102, 126, 234, 0.3);
  transition: all 0.2s ease;
}

.save-btn::after {
  border: none;
}

.save-btn:active {
  transform: scale(0.98);
  box-shadow: 0 3rpx 10rpx rgba(102, 126, 234, 0.3);
}

.save-btn[disabled] {
  opacity: 0.6;
}

.btn-icon {
  font-size: 28rpx;
}

/* ========== 操作按钮行 ========== */
.action-row {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.action-btn {
  height: 80rpx;
  padding: 0 28rpx;
  border-radius: 18rpx;
  font-size: 26rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  transition: all 0.2s ease;
}

.action-btn::after {
  border: none;
}

.action-btn.secondary {
  background: rgba(102, 126, 234, 0.1);
  color: #667eea;
}

.action-btn.secondary:active {
  background: rgba(102, 126, 234, 0.2);
}

.action-btn.ghost {
  background: rgba(239, 68, 68, 0.08);
  color: #ef4444;
}

.action-btn.ghost:active {
  background: rgba(239, 68, 68, 0.15);
}

.action-icon {
  font-size: 28rpx;
}

/* ========== Section 区域 ========== */
.section {
  margin-top: 32rpx;
}

.section-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
  padding: 0 8rpx;
}

.section-title {
  color: #374151;
  font-size: 28rpx;
  font-weight: 700;
  white-space: nowrap;
}

.section-line {
  flex: 1;
  height: 1rpx;
  background: linear-gradient(90deg, rgba(102, 126, 234, 0.3) 0%, transparent 100%);
}

/* ========== 通用卡片 ========== */
.card {
  background: #ffffff;
  border-radius: 28rpx;
  box-shadow:
    0 4rpx 20rpx rgba(102, 126, 234, 0.08),
    0 1rpx 4rpx rgba(0, 0, 0, 0.02);
  overflow: hidden;
}

/* ========== VIP 卡片 ========== */
.vip-card {
  position: relative;
  overflow: hidden;
}

.vip-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, #c4cad4 0%, #e5e7eb 100%);
}

.vip-card.is-vip::before {
  background: linear-gradient(90deg, #ffd700 0%, #ffb347 50%, #ffd700 100%);
}

.vip-header {
  padding: 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 24rpx;
}

.vip-info {
  flex: 1;
  min-width: 0;
}

.vip-title {
  display: flex;
  align-items: center;
  gap: 10rpx;
  color: #1a1a2e;
  font-size: 32rpx;
  font-weight: 700;
}

.vip-icon {
  font-size: 36rpx;
}

.vip-desc {
  margin-top: 8rpx;
  color: #9ca3af;
  font-size: 24rpx;
}

.vip-badge {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  padding: 16rpx 28rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #f8fafc 0%, #f0f4ff 100%);
}

.vip-card.is-vip .vip-badge {
  background: linear-gradient(135deg, #fff8e1 0%, #ffecb3 100%);
}

.badge-num {
  color: #667eea;
  font-size: 48rpx;
  font-weight: 800;
  line-height: 1;
}

.vip-card.is-vip .badge-num {
  color: #f59e0b;
}

.badge-unit {
  color: #9ca3af;
  font-size: 22rpx;
  font-weight: 600;
}

.vip-divider {
  height: 1rpx;
  background: linear-gradient(90deg, transparent 0%, rgba(102, 126, 234, 0.15) 50%, transparent 100%);
  margin: 0 32rpx;
}

.vip-details {
  padding: 24rpx 32rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.detail-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 20rpx;
  border-radius: 14rpx;
  background: #fafbfc;
}

.detail-label {
  color: #9ca3af;
  font-size: 24rpx;
}

.detail-value {
  color: #1a1a2e;
  font-size: 28rpx;
  font-weight: 600;
}

.detail-value.small {
  font-size: 24rpx;
  color: #6b7280;
}

.detail-value.highlight {
  color: #667eea;
  font-weight: 700;
}

.detail-value.success {
  color: #10b981;
}

/* VIP 按钮 */
.vip-btn {
  margin-top: 20rpx;
  height: 96rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 8rpx 24rpx rgba(245, 158, 11, 0.35);
  transition: all 0.2s ease;
}

.vip-btn::after {
  border: none;
}

.vip-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(245, 158, 11, 0.35);
}

/* ========== 菜单卡片 ========== */
.menu-card {
  padding: 0;
}

.menu-item {
  padding: 32rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  transition: background 0.2s ease;
}

.menu-item:active {
  background: #fafbfc;
}

.menu-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #f0f4ff 0%, #e8ecff 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.menu-content {
  flex: 1;
  min-width: 0;
}

.menu-title {
  color: #1a1a2e;
  font-size: 30rpx;
  font-weight: 600;
}

.menu-desc {
  margin-top: 6rpx;
  color: #9ca3af;
  font-size: 24rpx;
}

.menu-arrow {
  color: #c4cad4;
  font-size: 40rpx;
  line-height: 1;
  font-weight: 300;
}

/* ========== 底部安全区 ========== */
.safe-bottom {
  height: 40rpx;
}
