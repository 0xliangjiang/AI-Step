/* pages/my/my.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 用户卡片 */
.user-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 60rpx 40rpx;
  display: flex;
  align-items: center;
  gap: 28rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #667eea;
  font-weight: 700;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
}

.info .nickname {
  color: #fff;
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.vip-status {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.badge {
  background: linear-gradient(135deg, #ffd700, #ffaa00);
  color: #fff;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.badge.expired {
  background: rgba(255, 255, 255, 0.3);
}

.expire {
  color: rgba(255, 255, 255, 0.85);
  font-size: 24rpx;
}

/* 分区块 */
.section {
  margin: 24rpx;
}

.section-title {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
}

/* 开通会员按钮 */
.vip-btn {
  margin-top: 24rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  padding: 24rpx 0;
  border-radius: 50rpx;
}

/* 信息项 */
.item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.item:last-child {
  border-bottom: none;
}

.item .label {
  color: #666;
  font-size: 28rpx;
}

.item .value {
  color: #333;
  font-size: 28rpx;
}

.item .value.highlight {
  color: #667eea;
  font-weight: 700;
}

/* 菜单 */
.menu {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #f9f9f9;
}

.menu-text {
  color: #333;
  font-size: 28rpx;
}

.menu-arrow {
  color: #ccc;
  font-size: 28rpx;
}

/* 广告卡片 */
.ad-card {
  background: linear-gradient(135deg, #fff9e6 0%, #fff3cc 100%);
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border: 2rpx solid #ffe58f;
}

.ad-info {
  flex: 1;
}

.ad-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #d48806;
  margin-bottom: 8rpx;
}

.ad-desc {
  font-size: 24rpx;
  color: #fa8c16;
  margin-bottom: 6rpx;
}

.ad-count {
  font-size: 22rpx;
  color: #999;
}

.ad-btn {
  background: linear-gradient(135deg, #ffa940, #fa8c16);
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  padding: 18rpx 28rpx;
  border-radius: 30rpx;
  flex-shrink: 0;
  margin-left: 20rpx;
}

.ad-btn.disabled {
  background: #ccc;
  color: #fff;
}
