<!--pages/my/my.wxml-->
<view class="page">
  <!-- 渐变头部背景 -->
  <view class="header-bg"></view>

  <!-- 账户卡片 -->
  <view class="account-card">
    <!-- 头像区域 - 可点击更换 -->
    <view class="avatar-section">
      <button class="avatar-picker" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <view class="avatar-wrap">
          <image
            class="account-avatar"
            wx:if="{{displayAvatarUrl}}"
            src="{{displayAvatarUrl}}"
            mode="aspectFill"
            binderror="onAvatarError"
          ></image>
          <view class="account-avatar fallback" wx:else>{{avatarText}}</view>
          <view class="avatar-ring"></view>
        </view>
        <view class="avatar-edit-tip">点击更换</view>
      </button>
    </view>

    <!-- 昵称编辑 -->
    <view class="nickname-section" wx:if="{{isLoggedIn}}">
      <input
        class="nickname-input"
        type="nickname"
        placeholder="点击设置昵称"
        placeholder-class="nickname-placeholder"
        value="{{editNickname}}"
        bindinput="onNicknameInput"
        bindnicknamereview="onNicknameReview"
      />
      <text class="nickname-hint">点击上方头像或下方昵称可修改</text>
    </view>

    <!-- 未登录状态 -->
    <view class="login-section" wx:else>
      <view class="login-tip">登录后可保存个人资料</view>
      <button class="primary-btn login-btn" bindtap="handleLogin">
        <text class="btn-icon">👤</text>
        <text>微信一键登录</text>
      </button>
    </view>

    <!-- 状态标签 -->
    <view class="status-row" wx:if="{{isLoggedIn}}">
      <view class="status-chip {{isVip ? 'vip' : 'default'}}">
        <text class="chip-icon">{{isVip ? '✦' : '○'}}</text>
        <text>{{isVip ? '会员有效' : '体验中'}}</text>
      </view>
      <view class="status-chip {{hasProfile ? 'complete' : 'pending'}}">
        <text class="chip-icon">{{hasProfile ? '✓' : '!'}}</text>
        <text>{{hasProfile ? '资料已完善' : '资料待完善'}}</text>
      </view>
    </view>

    <!-- 统计区块 -->
    <view class="account-stats" wx:if="{{isLoggedIn}}">
      <view class="stat-block">
        <view class="stat-icon">⏱</view>
        <view class="stat-info">
          <view class="stat-value">{{isVip ? remainingDays + '天' : '体验中'}}</view>
          <view class="stat-label">会员状态</view>
        </view>
      </view>
      <view class="stat-block" wx:if="{{isVip}}">
        <view class="stat-icon">📅</view>
        <view class="stat-info">
          <view class="stat-value small">{{vipExpireAt}}</view>
          <view class="stat-label">到期时间</view>
        </view>
      </view>
    </view>

    <!-- 保存按钮 -->
    <button class="save-btn" wx:if="{{isLoggedIn}}" bindtap="saveProfile" loading="{{savingProfile}}" disabled="{{savingProfile}}">
      <text class="btn-icon" wx:if="{{!savingProfile}}">💾</text>
      <text>{{savingProfile ? '保存中...' : '保存资料'}}</text>
    </button>
  </view>

  <!-- 操作按钮 -->
  <view class="action-row" wx:if="{{isLoggedIn}}">
    <button class="action-btn secondary" bindtap="handleLogin">
      <text class="action-icon">🔄</text>
      <text>重新登录</text>
    </button>
    <button class="action-btn ghost" bindtap="handleLogout">
      <text class="action-icon">🚪</text>
      <text>退出登录</text>
    </button>
  </view>

  <!-- 会员卡片 -->
  <view class="section" wx:if="{{isLoggedIn && !reviewMode}}">
    <view class="section-header">
      <view class="section-title">会员信息</view>
      <view class="section-line"></view>
    </view>
    <view class="card vip-card {{isVip ? 'is-vip' : ''}}">
      <view class="vip-header">
        <view class="vip-info">
          <view class="vip-title">
            <text class="vip-icon">{{isVip ? '👑' : '⭐'}}</text>
            <text>{{isVip ? '会员服务已开通' : '体验会员'}}</text>
          </view>
          <view class="vip-desc">{{isVip ? '感谢您的支持，享受专属权益' : '开通会员查看更多功能'}}</view>
        </view>
        <view class="vip-badge">
          <text class="badge-num">{{isVip ? remainingDays : '0'}}</text>
          <text class="badge-unit">天</text>
        </view>
      </view>

      <view class="vip-divider"></view>

      <view class="vip-details">
        <view class="detail-item">
          <text class="detail-label">会员状态</text>
          <text class="detail-value {{isVip ? 'success' : ''}}">{{isVip ? '● 有效' : '○ 体验中'}}</text>
        </view>
        <view class="detail-item" wx:if="{{isVip}}">
          <text class="detail-label">到期时间</text>
          <text class="detail-value small">{{vipExpireAt}}</text>
        </view>
        <view class="detail-item">
          <text class="detail-label">剩余天数</text>
          <text class="detail-value highlight">{{remainingDays}} 天</text>
        </view>
      </view>
    </view>

    <button class="vip-btn" bindtap="goVip">
      <text class="btn-icon">{{isVip ? '💎' : '🚀'}}</text>
      <text>{{isVip ? '续费会员' : '立即开通'}}</text>
    </button>
  </view>

  <!-- 更多菜单 -->
  <view class="section">
    <view class="section-header">
      <view class="section-title">更多</view>
      <view class="section-line"></view>
    </view>
    <view class="card menu-card">
      <view class="menu-item" bindtap="aboutUs">
        <view class="menu-icon">ℹ️</view>
        <view class="menu-content">
          <view class="menu-title">关于我们</view>
          <view class="menu-desc">查看版本信息与应用说明</view>
        </view>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 底部安全区 -->
  <view class="safe-bottom"></view>
</view>
