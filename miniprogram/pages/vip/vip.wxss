/* pages/vip/vip.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF3E4 0%, #FFF8F0 36%, #FFFDF8 100%);
  padding-bottom: 120rpx;
}

.header {
  position: relative;
  overflow: hidden;
  background: linear-gradient(135deg, #FF8A3D 0%, #FFB457 42%, #39B8FF 100%);
  padding: 72rpx 40rpx 96rpx;
  text-align: center;
  border-radius: 0 0 48rpx 48rpx;
}

.header::after {
  content: '';
  position: absolute;
  right: -40rpx;
  top: 24rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.14);
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 12rpx;
  position: relative;
  z-index: 1;
}

.desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  position: relative;
  z-index: 1;
}

.packages {
  margin-top: -48rpx;
  padding: 0 24rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  position: relative;
  z-index: 2;
}

.package-item {
  width: calc(50% - 10rpx);
  background: rgba(255, 255, 255, 0.96);
  border-radius: 28rpx;
  padding: 32rpx 24rpx;
  text-align: center;
  position: relative;
  border: 4rpx solid transparent;
  box-shadow: 0 12rpx 32rpx rgba(22, 50, 79, 0.08);
}

.package-item.selected {
  border-color: #FF8A3D;
  background: linear-gradient(135deg, rgba(255, 138, 61, 0.12), rgba(57, 184, 255, 0.12));
  transform: translateY(-4rpx);
  box-shadow: 0 16rpx 40rpx rgba(255, 138, 61, 0.2);
}

.package-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #16324F;
  margin-bottom: 12rpx;
}

.package-days {
  font-size: 24rpx;
  color: #8B9AA7;
  margin-bottom: 16rpx;
}

.package-price {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 8rpx;
}

.package-price .price {
  font-size: 40rpx;
  font-weight: 700;
  color: #FF8A3D;
}

.package-price .original {
  font-size: 24rpx;
  color: #8B9AA7;
  text-decoration: line-through;
}

.check-icon {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 40rpx;
  height: 40rpx;
  background: #FF8A3D;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.benefits {
  margin: 24rpx;
  background: rgba(255, 255, 255, 0.96);
  border-radius: 28rpx;
  padding: 32rpx;
  box-shadow: 0 12rpx 32rpx rgba(22, 50, 79, 0.06);
}

.benefits-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #16324F;
  margin-bottom: 24rpx;
}

.benefit-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.benefit-item:last-child {
  margin-bottom: 0;
}

.benefit-icon {
  width: 36rpx;
  height: 36rpx;
  background: linear-gradient(135deg, #FF8A3D, #39B8FF);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
}

.benefit-item text:last-child {
  font-size: 28rpx;
  color: #6C7F90;
}

.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 -8rpx 24rpx rgba(22, 50, 79, 0.06);
  backdrop-filter: blur(16rpx);
}

.pay-btn {
  background: linear-gradient(135deg, #FF8A3D 0%, #F06B1F 48%, #39B8FF 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  padding: 28rpx 0;
  border-radius: 50rpx;
  box-shadow: 0 10rpx 24rpx rgba(255, 138, 61, 0.28);
}

.pay-btn[disabled] {
  background: #D8C8B6;
  box-shadow: none;
}
