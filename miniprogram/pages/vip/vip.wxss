/* pages/vip/vip.wxss */
.container {
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(57, 184, 255, 0.18) 0, rgba(57, 184, 255, 0) 28%),
    linear-gradient(180deg, #FFF2E2 0%, #FFF8F0 42%, #FFFDF9 100%);
  padding-bottom: 220rpx;
}

.header {
  position: relative;
  overflow: hidden;
  background: linear-gradient(135deg, #FF8A3D 0%, #FFB457 48%, #57B7F5 100%);
  padding: 68rpx 36rpx 118rpx;
  text-align: center;
  border-radius: 0 0 44rpx 44rpx;
}

.header::before,
.header::after {
  content: '';
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
}

.header::before {
  right: -52rpx;
  top: 32rpx;
  width: 220rpx;
  height: 220rpx;
  background: rgba(255, 255, 255, 0.16);
}

.header::after {
  left: -40rpx;
  bottom: -58rpx;
  width: 180rpx;
  height: 180rpx;
  background: rgba(255, 255, 255, 0.1);
}

.title,
.desc {
  position: relative;
  z-index: 1;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 12rpx;
}

.desc {
  font-size: 25rpx;
  color: rgba(255, 255, 255, 0.84);
}

.packages-tip,
.packages-error,
.packages-empty,
.benefits {
  margin: 24rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 30rpx;
  box-shadow: 0 18rpx 46rpx rgba(33, 44, 67, 0.08);
}

.packages-tip,
.packages-error,
.packages-empty {
  padding: 24rpx 28rpx;
  color: #6C7F90;
}

.packages-tip {
  margin-top: -30rpx;
  position: relative;
  z-index: 3;
  border: 2rpx solid rgba(87, 183, 245, 0.24);
}

.packages-error,
.packages-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 18rpx;
  text-align: center;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #16324F;
}

.empty-desc {
  font-size: 25rpx;
  color: #8B9AA7;
  line-height: 1.5;
}

.retry-btn {
  min-width: 220rpx;
  padding: 0 28rpx;
  line-height: 72rpx;
  border-radius: 999rpx;
  border: 2rpx solid rgba(255, 138, 61, 0.28);
  background: rgba(255, 138, 61, 0.08);
  color: #FF8A3D;
  font-size: 28rpx;
  font-weight: 600;
}

.package-spotlight {
  position: relative;
  z-index: 2;
  margin: -56rpx 24rpx 28rpx;
}

.spotlight-caption {
  margin: 0 8rpx 16rpx;
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  color: rgba(22, 50, 79, 0.74);
}

.package-hero {
  position: relative;
  overflow: hidden;
  border-radius: 34rpx;
  padding: 32rpx 30rpx 30rpx;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(255, 247, 241, 0.98) 100%);
  border: 3rpx solid rgba(255, 182, 120, 0.55);
  box-shadow:
    0 20rpx 44rpx rgba(255, 138, 61, 0.14),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.78);
}

.package-hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at top right, rgba(87, 183, 245, 0.18), rgba(87, 183, 245, 0) 34%),
    radial-gradient(circle at bottom left, rgba(255, 180, 87, 0.16), rgba(255, 180, 87, 0) 28%);
  pointer-events: none;
}

.package-hero.selected {
  transform: translateY(-6rpx);
  box-shadow:
    0 24rpx 54rpx rgba(255, 138, 61, 0.2),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
}

.package-headline,
.package-main,
.package-price-row,
.package-meta-row,
.package-price-note {
  position: relative;
  z-index: 1;
}

.package-headline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 26rpx;
}

.package-pill,
.package-select-chip,
.package-meta-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  white-space: nowrap;
}

.package-pill {
  min-width: 110rpx;
  padding: 0 22rpx;
  line-height: 52rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: #FF7A1A;
  background: rgba(255, 138, 61, 0.14);
}

.package-select-chip {
  padding: 0 20rpx;
  line-height: 48rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: #6C7F90;
  background: rgba(22, 50, 79, 0.06);
}

.package-hero.selected .package-select-chip {
  color: #fff;
  background: linear-gradient(135deg, #FF8A3D, #57B7F5);
}

.package-main {
  margin-bottom: 20rpx;
}

.package-name {
  font-size: 42rpx;
  line-height: 1.15;
  font-weight: 700;
  color: #16324F;
  margin-bottom: 10rpx;
}

.package-days {
  font-size: 25rpx;
  line-height: 1.45;
  color: #708395;
}

.package-price-row {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 22rpx;
}

.package-price {
  display: flex;
  align-items: baseline;
  color: #FF7A1A;
}

.price-symbol {
  font-size: 34rpx;
  font-weight: 700;
  margin-right: 4rpx;
}

.package-price .price {
  font-size: 62rpx;
  line-height: 1;
  font-weight: 800;
  letter-spacing: -1rpx;
}

.original {
  font-size: 24rpx;
  color: #93A0AE;
  text-decoration: line-through;
  margin-bottom: 8rpx;
}

.package-meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.package-meta-pill {
  padding: 0 18rpx;
  line-height: 46rpx;
  font-size: 22rpx;
  color: #5E7387;
  background: rgba(255, 255, 255, 0.78);
  border: 1rpx solid rgba(22, 50, 79, 0.06);
}

.package-price-note {
  font-size: 24rpx;
  line-height: 1.6;
  color: #6C7F90;
  padding-right: 42rpx;
}

.check-icon {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  width: 46rpx;
  height: 46rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF8A3D, #57B7F5);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
  box-shadow: 0 10rpx 24rpx rgba(255, 138, 61, 0.24);
}

.benefits {
  padding: 32rpx 30rpx;
}

.benefits-title {
  font-size: 31rpx;
  font-weight: 700;
  color: #16324F;
  margin-bottom: 22rpx;
}

.benefit-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.benefit-item:last-child {
  margin-bottom: 0;
}

.benefit-icon {
  width: 36rpx;
  height: 36rpx;
  margin-top: 2rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(255, 138, 61, 0.22), rgba(87, 183, 245, 0.22));
  color: #FF7A1A;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
}

.benefit-item text:last-child {
  flex: 1;
  font-size: 28rpx;
  line-height: 1.6;
  color: #627486;
}

.footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.94);
  backdrop-filter: blur(18rpx);
  box-shadow: 0 -10rpx 30rpx rgba(22, 50, 79, 0.08);
}

.footer-summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 14rpx;
  padding: 0 10rpx;
}

.footer-summary-label {
  font-size: 22rpx;
  color: #7A8896;
}

.footer-summary-value {
  font-size: 25rpx;
  font-weight: 700;
  color: #16324F;
}

.pay-btn {
  background: linear-gradient(135deg, #FF8A3D 0%, #F06B1F 52%, #57B7F5 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 88rpx;
  border-radius: 999rpx;
  box-shadow: 0 14rpx 30rpx rgba(255, 138, 61, 0.24);
}

.pay-btn[disabled] {
  background: #D8C8B6;
  box-shadow: none;
}

@media (max-width: 360px) {
  .header {
    padding: 60rpx 28rpx 104rpx;
  }

  .package-spotlight,
  .packages-tip,
  .packages-error,
  .packages-empty,
  .benefits {
    margin-left: 18rpx;
    margin-right: 18rpx;
  }

  .package-hero {
    padding: 28rpx 24rpx 26rpx;
  }

  .package-name {
    font-size: 38rpx;
  }

  .package-price .price {
    font-size: 56rpx;
  }

  .package-price-note,
  .benefit-item text:last-child {
    font-size: 25rpx;
  }

  .footer {
    padding-left: 18rpx;
    padding-right: 18rpx;
  }
}
