<!--pages/vip/vip.wxml-->
<view class="container">
  <!-- 标题 -->
  <view class="header">
    <view class="title">开通会员服务</view>
    <view class="desc">把运动记录和同步体验升级</view>
  </view>

  <view class="packages-tip" wx:if="{{usingCachedPackages}}">
    套餐正在刷新，当前先展示上次可用内容。
  </view>

  <view class="packages-error" wx:if="{{loadError}}">
    <text>{{loadError}}</text>
    <button class="retry-btn" bindtap="refreshPackages">重新加载</button>
  </view>

  <!-- 套餐列表 -->
  <view class="packages" wx:if="{{packages.length}}">
    <view
      class="package-item {{selectedPackage && selectedPackage.id === item.id ? 'selected' : ''}}"
      wx:for="{{packages}}"
      wx:key="id"
      bindtap="selectPackage"
      data-id="{{item.id}}"
    >
      <view class="package-name">{{item.name}}</view>
      <view class="package-days">{{item.days}}天</view>
      <view class="package-price">
        <text class="price">¥{{item.price / 100}}</text>
        <text class="original" wx:if="{{item.original_price}}">¥{{item.original_price / 100}}</text>
      </view>
      <view class="check-icon" wx:if="{{selectedPackage && selectedPackage.id === item.id}}">✓</view>
    </view>
  </view>

  <view class="packages-empty" wx:elif="{{!loading}}">
    <view class="empty-title">套餐暂时没加载出来</view>
    <view class="empty-desc">可以重新加载一次，稍后再回来看看。</view>
    <button class="retry-btn" bindtap="refreshPackages">重新加载</button>
  </view>

  <!-- 权益说明 -->
  <view class="benefits">
    <view class="benefits-title">会员权益</view>
    <view class="benefit-item">
      <text class="benefit-icon">✓</text>
      <text>不限次查看运动复盘</text>
    </view>
    <view class="benefit-item">
      <text class="benefit-icon">✓</text>
      <text>优先同步与稳定记录</text>
    </view>
    <view class="benefit-item">
      <text class="benefit-icon">✓</text>
      <text>专属记录参考与同步说明</text>
    </view>
  </view>

  <!-- 底部按钮 -->
  <view class="footer">
    <button class="pay-btn" bindtap="createOrder" disabled="{{paying || !selectedPackage}}">
      {{paying ? '开通中...' : selectedPackage ? '立即开通 ¥' + (selectedPackage.price / 100) : '先选一个会员套餐'}}
    </button>
  </view>
</view>
