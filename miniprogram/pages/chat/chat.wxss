/* pages/chat/chat.wxss */
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

.message-list {
  flex: 1;
  padding: 20rpx;
  overflow: hidden;
}

.message-item {
  display: flex;
  margin-bottom: 30rpx;
  align-items: flex-start;
}

.message-item.user {
  flex-direction: row-reverse;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea, #764ba2);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar text {
  color: white;
  font-size: 28rpx;
  font-weight: bold;
}

.content {
  max-width: 70%;
  margin: 0 20rpx;
}

.bubble {
  background: white;
  padding: 24rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-all;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.message-item.user .bubble {
  background: #667eea;
  color: white;
}

.bubble .images {
  margin-top: 20rpx;
}

.bubble .images image {
  max-width: 100%;
  border-radius: 8rpx;
}

.loading {
  display: flex;
  justify-content: center;
  gap: 10rpx;
  padding: 20rpx;
}

.loading-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #667eea;
  animation: bounce 1s infinite;
}

.loading-dot:nth-child(2) {
  animation-delay: 0.2s;
}

.loading-dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

.quick-actions {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 20rpx;
  background: white;
  border-top: 1rpx solid #eee;
}

.quick-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #667eea;
  background: #f5f5f5;
  border-radius: 30rpx;
}

.input-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background: white;
  border-top: 1rpx solid #eee;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}

.input {
  flex: 1;
  background: #f5f5f5;
  border-radius: 40rpx;
  padding: 20rpx 30rpx;
  font-size: 28rpx;
}

.send-btn {
  margin-left: 16rpx;
  background: #667eea;
  color: white;
  font-size: 28rpx;
  padding: 20rpx 30rpx;
  border-radius: 40rpx;
  border: none;
}

.send-btn::after {
  border: none;
}

.send-btn[disabled] {
  background: #ccc;
}
