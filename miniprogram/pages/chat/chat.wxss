/* pages/chat/chat.wxss */

.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f7f8fc;
}

.chat-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx 24rpx 20rpx;
  background: #fff;
  border-bottom: 1rpx solid #eef0f6;
}

.chat-header-avatar {
  width: 84rpx;
  height: 84rpx;
  border-radius: 24rpx;
  flex-shrink: 0;
}

.chat-header-avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
}

.chat-header-info {
  min-width: 0;
}

.chat-header-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.chat-header-desc {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #8a8fa3;
}

/* 消息区域 */
.message-area {
  flex: 1;
  overflow: hidden;
}

/* 欢迎页 */
.welcome {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx 40rpx;
}

.welcome-icon {
  width: 160rpx;
  height: 160rpx;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  box-shadow: 0 20rpx 40rpx rgba(99, 102, 241, 0.3);
}

.welcome-logo {
  font-size: 56rpx;
  font-weight: 700;
  color: #fff;
}

.welcome-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 16rpx;
}

.welcome-desc {
  font-size: 28rpx;
  color: #6b7280;
  margin-bottom: 8rpx;
}

.suggest-list {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  width: 100%;
  margin-top: 48rpx;
}

.suggest-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 20rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.suggest-item:active {
  background: #f3f4f6;
}

.suggest-icon {
  font-size: 40rpx;
  margin-bottom: 12rpx;
}

.suggest-text {
  font-size: 26rpx;
  color: #374151;
}

/* 消息样式 */
.msg {
  display: flex;
  padding: 20rpx 24rpx;
  align-items: flex-start;
}

.msg.user {
  flex-direction: row-reverse;
}

.msg-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}

.msg-avatar open-data {
  width: 100%;
  height: 100%;
}

.msg-avatar image {
  width: 100%;
  height: 100%;
}

.msg.assistant .msg-avatar {
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
}

.msg-avatar text {
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
}

.msg-content {
  max-width: 68%;
  margin: 0 16rpx;
}

.msg-bubble {
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-word;
}

.msg.assistant .msg-bubble {
  background: #fff;
  color: #1a1a2e;
  border-bottom-left-radius: 6rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.msg.user .msg-bubble {
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  color: #fff;
  border-bottom-right-radius: 6rpx;
}

.msg-text {
  white-space: pre-wrap;
}

.msg-images {
  margin-top: 16rpx;
}

.msg-img {
  max-width: 300rpx;
  border-radius: 12rpx;
}

/* 加载动画 */
.typing {
  display: flex;
  padding: 20rpx 24rpx;
  align-items: center;
}

.typing-dots {
  display: flex;
  gap: 8rpx;
  padding: 20rpx 24rpx;
  background: #fff;
  border-radius: 20rpx;
  margin-left: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #9ca3af;
  animation: bounce 1.2s infinite;
}

.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes bounce {
  0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
  30% { transform: translateY(-10rpx); opacity: 1; }
}

#bottom {
  height: 20rpx;
}

/* 底部输入区 */
.input-area {
  background: #fff;
  border-top: 1rpx solid #eee;
  padding-bottom: env(safe-area-inset-bottom);
}

/* 快捷操作滚动 */
.quick-scroll {
  width: 100%;
  white-space: nowrap;
}

.quick-list {
  display: inline-flex;
  padding: 16rpx 24rpx;
  gap: 16rpx;
}

.quick-item {
  flex-shrink: 0;
  padding: 14rpx 28rpx;
  font-size: 26rpx;
  color: #6366f1;
  background: #f5f3ff;
  border-radius: 24rpx;
  border: 1rpx solid #e0e7ff;
}

.quick-item:active {
  background: #e0e7ff;
}

/* 输入行 */
.input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 24rpx;
}

.input {
  flex: 1;
  height: 80rpx;
  background: #f3f4f6;
  border-radius: 40rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
}

.send-btn {
  width: 120rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
  line-height: 1;
}

.send-btn::after {
  border: none;
}

.send-btn[disabled] {
  background: #d1d5db;
  color: #9ca3af;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-box {
  width: 600rpx;
  background: #fff;
  border-radius: 28rpx;
  padding: 48rpx 40rpx;
}

.modal-icon {
  font-size: 72rpx;
  text-align: center;
  margin-bottom: 16rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a2e;
  text-align: center;
  margin-bottom: 40rpx;
}

.modal-form {
  margin-bottom: 40rpx;
}

.form-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.form-label {
  width: 140rpx;
  font-size: 28rpx;
  color: #6b7280;
  flex-shrink: 0;
}

.form-picker {
  flex: 1;
  height: 80rpx;
  background: #f3f4f6;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #1a1a2e;
}

.arrow {
  font-size: 20rpx;
  color: #9ca3af;
}

.form-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background: #f3f4f6;
  border-radius: 16rpx;
  height: 80rpx;
  padding: 0 24rpx;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #1a1a2e;
  height: 100%;
}

.form-unit {
  font-size: 28rpx;
  color: #6366f1;
  font-weight: 600;
  margin-left: 12rpx;
}

.modal-btns {
  display: flex;
  gap: 24rpx;
}

.modal-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
  line-height: 1;
}

.modal-btn::after {
  border: none;
}

.modal-btn.cancel {
  background: #f3f4f6;
  color: #6b7280;
}

.modal-btn.confirm {
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  color: #fff;
}
