/* pages/chat/chat.wxss */
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

/* 消息列表 */
.message-list {
  flex: 1;
  padding: 24rpx;
}

.message-item {
  display: flex;
  margin-bottom: 24rpx;
  align-items: flex-start;
}

.message-item.user {
  flex-direction: row-reverse;
}

/* 头像 */
.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea, #764ba2);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}

.avatar.user {
  background: transparent;
}

.avatar open-data {
  width: 100%;
  height: 100%;
  display: block;
}

.avatar text {
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
}

/* 消息内容 */
.content {
  max-width: 70%;
  margin: 0 16rpx;
}

.bubble {
  background: #fff;
  padding: 24rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-word;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.message-item.user .bubble {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
}

/* 图片 */
.bubble .images {
  margin-top: 16rpx;
}

.bubble .images image {
  max-width: 100%;
  border-radius: 12rpx;
}

/* 加载动画 */
.loading {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  padding: 20rpx;
}

.loading-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #667eea;
  animation: bounce 1s infinite;
}

.loading-dot:nth-child(2) { animation-delay: 0.2s; }
.loading-dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-12rpx); }
}

/* 快捷操作 */
.quick-actions {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  background: #fff;
  overflow-x: auto;
}

.quick-btn {
  flex-shrink: 0;
  padding: 16rpx 28rpx;
  font-size: 26rpx;
  color: #667eea;
  background: #f5f5f5;
  border-radius: 30rpx;
}

.quick-btn:active {
  background: #e8e8e8;
}

/* 输入栏 */
.input-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #eee;
}

.input {
  flex: 1;
  background: #f5f5f5;
  border-radius: 40rpx;
  padding: 20rpx 28rpx;
  font-size: 28rpx;
}

.send-btn {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  padding: 20rpx 32rpx;
  border-radius: 40rpx;
}

.send-btn[disabled] {
  background: #ccc;
}

#bottom {
  height: 20rpx;
}

/* 分享弹窗 */
.share-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.share-content {
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
}

.share-icon {
  font-size: 64rpx;
  text-align: center;
  margin-bottom: 16rpx;
}

.share-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
  text-align: center;
  margin-bottom: 32rpx;
}

.share-form {
  margin-bottom: 32rpx;
}

.form-item {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.form-label {
  width: 140rpx;
  font-size: 28rpx;
  color: #666;
  flex-shrink: 0;
}

.picker-value {
  flex: 1;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
}

.picker-arrow {
  font-size: 20rpx;
  color: #999;
}

.value-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 12rpx;
  height: 72rpx;
  padding: 0 24rpx;
}

.value-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  height: 100%;
}

.value-unit {
  font-size: 28rpx;
  color: #667eea;
  font-weight: 500;
  margin-left: 12rpx;
}

.share-btns {
  display: flex;
  gap: 24rpx;
}

.share-btn {
  flex: 1;
  padding: 24rpx 0;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.share-btn.cancel {
  background: #f5f5f5;
  color: #666;
}

.share-btn.confirm {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
}
