/* pages/chat/chat.wxss */

/* ========== 页面基础 ========== */
.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #FFF8F0 0%, #FFFDF8 100%);
}

/* ========== 顶部导航 ========== */
.chat-header {
  position: relative;
  padding: 0 24rpx;
  padding-top: constant(safe-area-inset-top);
  padding-top: env(safe-area-inset-top);
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 100%;
  background: linear-gradient(135deg, #FF8A3D 0%, #39B8FF 100%);
  z-index: 0;
}

.header-content {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 0;
}

.avatar-wrap {
  position: relative;
  flex-shrink: 0;
}

.header-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.header-avatar.fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.2);
  color: #FFFFFF;
  font-size: 36rpx;
  font-weight: 700;
}

.header-info {
  flex: 1;
  min-width: 0;
}

.header-name {
  color: #FFFFFF;
  font-size: 34rpx;
  font-weight: 700;
}

.header-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 6rpx;
  color: rgba(255, 255, 255, 0.85);
  font-size: 24rpx;
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #28C69A;
  box-shadow: 0 0 8rpx rgba(74, 222, 128, 0.6);
}

/* ========== 消息区域 ========== */
.message-area {
  flex: 1;
  overflow: hidden;
}

/* ========== 欢迎页 ========== */
.welcome {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 32rpx 40rpx;
}

.welcome-hero {
  text-align: center;
  margin-bottom: 48rpx;
}

.welcome-icon {
  width: 140rpx;
  height: 140rpx;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #FF8A3D 0%, #39B8FF 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 24rpx;
  box-shadow: 0 12rpx 32rpx rgba(255, 138, 61, 0.28);
}

.welcome-logo {
  font-size: 56rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.welcome-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #16324F;
  margin-bottom: 12rpx;
}

.welcome-desc {
  font-size: 26rpx;
  color: #6C7F90;
  line-height: 1.6;
}

.suggest-list {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  width: 100%;
}

.suggest-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 20rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(22, 50, 79, 0.07);
  transition: all 0.2s ease;
}

.suggest-item:active {
  transform: scale(0.96);
  background: #FFF7EF;
}

.suggest-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #FFF1E2 0%, #E6F7FF 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.suggest-icon {
  font-size: 32rpx;
}

.suggest-text {
  font-size: 26rpx;
  color: #23415F;
  font-weight: 600;
}

/* ========== 消息样式 ========== */
.msg {
  display: flex;
  padding: 16rpx 24rpx;
  align-items: flex-start;
}

.msg.user {
  flex-direction: row-reverse;
}

.msg-avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  flex-shrink: 0;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.msg-avatar image {
  width: 100%;
  height: 100%;
}

.ai-avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF8A3D 0%, #39B8FF 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(57, 184, 255, 0.24);
}

.ai-avatar text {
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 700;
}

.msg-avatar text {
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
}

.msg-content {
  max-width: 65%;
  margin: 0 16rpx;
}

.msg-bubble {
  padding: 20rpx 24rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-word;
}

.msg.assistant .msg-bubble {
  background: #FFFFFF;
  color: #16324F;
  border-bottom-left-radius: 8rpx;
  box-shadow: 0 2rpx 12rpx rgba(22, 50, 79, 0.07);
}

.msg.user .msg-bubble {
  background: linear-gradient(135deg, #FF8A3D 0%, #39B8FF 100%);
  color: #FFFFFF;
  border-bottom-right-radius: 8rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 138, 61, 0.22);
}

.msg-text {
  white-space: pre-wrap;
}

.msg-images {
  margin-top: 16rpx;
}

.msg-img {
  max-width: 280rpx;
  border-radius: 16rpx;
}

/* ========== 加载动画 ========== */
.typing {
  display: flex;
  padding: 16rpx 24rpx;
  align-items: flex-start;
}

.typing-bubble {
  margin-left: 16rpx;
  padding: 20rpx 28rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  border-bottom-left-radius: 8rpx;
  box-shadow: 0 2rpx 12rpx rgba(22, 50, 79, 0.07);
}

.typing-dots {
  display: flex;
  gap: 8rpx;
  align-items: center;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF8A3D 0%, #39B8FF 100%);
  animation: bounce 1.2s infinite;
}

.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes bounce {
  0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
  30% { transform: translateY(-12rpx); opacity: 1; }
}

#bottom {
  height: 20rpx;
}

/* ========== 底部输入区 ========== */
.input-area {
  background: #FFFFFF;
  border-top: 1rpx solid rgba(22, 50, 79, 0.08);
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* 快捷操作 */
.quick-scroll {
  width: 100%;
  white-space: nowrap;
}

.quick-list {
  display: inline-flex;
  padding: 16rpx 24rpx;
  gap: 16rpx;
}

.quick-item {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 24rpx;
  background: linear-gradient(135deg, #FFF1E2 0%, #E6F7FF 100%);
  border-radius: 999rpx;
  font-size: 26rpx;
  color: #FF8A3D;
  font-weight: 600;
  transition: all 0.2s ease;
}

.quick-item:active {
  transform: scale(0.96);
  background: linear-gradient(135deg, #e0e7ff 0%, #dbeafe 100%);
}

.quick-icon {
  font-size: 24rpx;
}

/* 输入行 */
.input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 24rpx;
}

.input {
  flex: 1;
  height: 88rpx;
  background: #FFFDF8;
  border-radius: 24rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
  color: #16324F;
}

.input-placeholder {
  color: #D8C8B6;
}

.send-btn {
  width: 88rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #FF8A3D 0%, #39B8FF 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
  box-shadow: 0 4rpx 16rpx rgba(57, 184, 255, 0.24);
  transition: all 0.2s ease;
}

.send-btn::after {
  border: none;
}

.send-btn:active {
  transform: scale(0.92);
}

.send-btn[disabled] {
  background: #e5e7eb;
  box-shadow: none;
}

.send-btn[disabled] .send-icon {
  color: #D8C8B6;
}

.send-icon {
  color: #FFFFFF;
  font-size: 32rpx;
}

/* ========== 弹窗 ========== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-box {
  width: 620rpx;
  background: #FFFFFF;
  border-radius: 32rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 32rpx 32rpx;
  background: linear-gradient(135deg, #FFF1E2 0%, #E6F7FF 100%);
}

.modal-icon {
  font-size: 64rpx;
  margin-bottom: 12rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #16324F;
}

.modal-form {
  padding: 32rpx;
}

.form-item {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  width: 140rpx;
  font-size: 28rpx;
  color: #6C7F90;
  flex-shrink: 0;
}

.form-picker {
  flex: 1;
  height: 88rpx;
  background: #FFFDF8;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #16324F;
}

.picker-arrow {
  font-size: 20rpx;
  color: #8B9AA7;
}

.form-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background: #FFFDF8;
  border-radius: 18rpx;
  height: 88rpx;
  padding: 0 24rpx;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #16324F;
  height: 100%;
}

.form-unit {
  font-size: 28rpx;
  color: #FF8A3D;
  font-weight: 600;
  margin-left: 12rpx;
}

.modal-btns {
  display: flex;
  gap: 20rpx;
  padding: 0 32rpx 32rpx;
}

.modal-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 20rpx;
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
  transition: all 0.2s ease;
}

.modal-btn::after {
  border: none;
}

.modal-btn:active {
  transform: scale(0.98);
}

.modal-btn.cancel {
  background: #FFFDF8;
  color: #6C7F90;
}

.modal-btn.confirm {
  background: linear-gradient(135deg, #FF8A3D 0%, #39B8FF 100%);
  color: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(57, 184, 255, 0.24);
}

.login-gate-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 1200;
  background: rgba(15, 33, 51, 0.42);
  backdrop-filter: blur(10rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
}

.login-gate-card {
  width: 100%;
  max-width: 620rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, #FFFFFF 100%);
  border-radius: 36rpx;
  padding: 44rpx 36rpx 36rpx;
  box-shadow: 0 24rpx 72rpx rgba(17, 49, 79, 0.2);
  text-align: center;
}

.login-gate-badge {
  width: 108rpx;
  height: 108rpx;
  margin: 0 auto 20rpx;
  border-radius: 30rpx;
  background: linear-gradient(135deg, #FF8A3D 0%, #39B8FF 100%);
  color: #FFFFFF;
  font-size: 46rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 32rpx rgba(255, 138, 61, 0.24);
}

.login-gate-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #16324F;
}

.login-gate-desc {
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #6C7F90;
}

.login-gate-button {
  margin-top: 28rpx;
  height: 92rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #28C69A 0%, #1FA67F 100%);
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 28rpx rgba(31, 166, 127, 0.22);
}

.login-gate-button::after {
  border: none;
}
