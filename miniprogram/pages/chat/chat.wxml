<!--pages/chat/chat.wxml-->
<view class="page">
  <!-- 顶部导航 -->
  <view class="chat-header">
    <view class="header-bg"></view>
    <view class="header-content">
      <view class="avatar-wrap">
        <image
          class="header-avatar"
          wx:if="{{userProfile && userProfile.avatarUrl}}"
          src="{{userProfile.avatarUrl}}"
          mode="aspectFill"
        ></image>
        <view class="header-avatar fallback" wx:else>{{avatarText}}</view>
      </view>
      <view class="header-info">
        <view class="header-name">{{(userProfile && userProfile.nickName) || '微信用户'}}</view>
        <view class="header-status">
          <view class="status-dot"></view>
          <text>在线服务中</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 消息区域 -->
  <scroll-view
    class="message-area"
    scroll-y
    scroll-into-view="{{scrollToView}}"
    scroll-with-animation
  >
    <!-- 欢迎页 -->
    <view class="welcome" wx:if="{{messages.length === 0}}">
      <view class="welcome-hero">
        <view class="welcome-icon">
          <text class="welcome-logo">记</text>
        </view>
        <view class="welcome-title">运动记录助手</view>
        <view class="welcome-desc">我可以帮你记录运动数据、查看健康趋势、制定健身计划</view>
      </view>

      <view class="suggest-list">
        <view class="suggest-item" bindtap="quickAction" data-action="帮我记录今天的运动">
          <view class="suggest-icon-wrap">
            <text class="suggest-icon">✅</text>
          </view>
          <view class="suggest-text">运动打卡</view>
        </view>
        <view class="suggest-item" bindtap="quickAction" data-action="查看今日健康数据">
          <view class="suggest-icon-wrap">
            <text class="suggest-icon">👟</text>
          </view>
          <view class="suggest-text">健康数据</view>
        </view>
        <view class="suggest-item" bindtap="quickAction" data-action="帮我制定一个健身计划">
          <view class="suggest-icon-wrap">
            <text class="suggest-icon">📋</text>
          </view>
          <view class="suggest-text">健身计划</view>
        </view>
        <view class="suggest-item" bindtap="quickAction" data-action="分享一些跑步技巧">
          <view class="suggest-icon-wrap">
            <text class="suggest-icon">🏃</text>
          </view>
          <view class="suggest-text">跑步技巧</view>
        </view>
      </view>
    </view>

    <!-- 消息列表 -->
    <view wx:for="{{messages}}" wx:key="index" class="msg {{item.role}}">
      <view class="msg-avatar">
        <image wx:if="{{item.role === 'user' && userProfile && userProfile.avatarUrl}}" src="{{userProfile.avatarUrl}}" mode="aspectFill"></image>
        <text wx:elif="{{item.role === 'user'}}">{{avatarText}}</text>
        <view class="ai-avatar" wx:else>
          <text>记</text>
        </view>
      </view>
      <view class="msg-content">
        <view class="msg-bubble">
          <text class="msg-text">{{item.content}}</text>
          <view class="msg-images" wx:if="{{item.images && item.images.length > 0}}">
            <image
              wx:for="{{item.images}}"
              wx:for-item="img"
              wx:key="index"
              src="{{img.data.indexOf('data:') === 0 ? img.data : 'data:image/png;base64,' + img.data}}"
              mode="widthFix"
              class="msg-img"
              bindtap="previewImage"
              data-src="{{img.data.indexOf('data:') === 0 ? img.data : 'data:image/png;base64,' + img.data}}"
            />
          </view>
        </view>
      </view>
    </view>

    <!-- 加载中 -->
    <view class="typing" wx:if="{{loading}}">
      <view class="msg-avatar">
        <view class="ai-avatar">
          <text>记</text>
        </view>
      </view>
      <view class="typing-bubble">
        <view class="typing-dots">
          <view class="dot"></view>
          <view class="dot"></view>
          <view class="dot"></view>
        </view>
      </view>
    </view>

    <view id="bottom"></view>
  </scroll-view>

  <!-- 底部输入区 -->
  <view class="input-area">
    <!-- 快捷操作 -->
    <scroll-view class="quick-scroll" scroll-x wx:if="{{messages.length > 0}}">
      <view class="quick-list">
        <view class="quick-item" bindtap="quickAction" data-action="今天运动打卡">
          <text class="quick-icon">✅</text>
          <text>记录</text>
        </view>
        <view class="quick-item" bindtap="quickAction" data-action="查看今日健康数据">
          <text class="quick-icon">👟</text>
          <text>健康</text>
        </view>
        <view class="quick-item" bindtap="quickAction" data-action="推荐健身动作">
          <text class="quick-icon">💪</text>
          <text>健身</text>
        </view>
        <view class="quick-item" bindtap="quickAction" data-action="分享运动技巧">
          <text class="quick-icon">💡</text>
          <text>技巧</text>
        </view>
        <view class="quick-item" bindtap="quickAction" data-action="制定运动计划">
          <text class="quick-icon">📋</text>
          <text>计划</text>
        </view>
        <view class="quick-item" bindtap="openShareModal">
          <text class="quick-icon">🏃</text>
          <text>分享运动</text>
        </view>
      </view>
    </scroll-view>

    <!-- 输入框 -->
    <view class="input-row">
      <input
        class="input"
        type="text"
        value="{{inputText}}"
        placeholder="输入消息..."
        placeholder-class="input-placeholder"
        bindinput="onInput"
        confirm-type="send"
        bindconfirm="sendMessage"
        adjust-position="{{true}}"
      />
      <button class="send-btn" bindtap="sendMessage" disabled="{{loading || !inputText}}">
        <text class="send-icon">➤</text>
      </button>
    </view>
  </view>

  <!-- 分享弹窗 -->
  <view class="modal-mask" wx:if="{{showShareModal}}" bindtap="closeShareModal">
    <view class="modal-box" catchtap>
      <view class="modal-header">
        <text class="modal-icon">🏃</text>
        <text class="modal-title">同步运动数据</text>
      </view>

      <view class="modal-form">
        <view class="form-item">
          <text class="form-label">运动类型</text>
          <picker mode="selector" range="{{sportTypes}}" range-key="name" value="{{selectedSportIndex}}" bindchange="onSportTypeChange">
            <view class="form-picker">
              <text>{{sportTypes[selectedSportIndex].name}}</text>
              <text class="picker-arrow">▼</text>
            </view>
          </picker>
        </view>

        <view class="form-item">
          <text class="form-label">单位</text>
          <picker mode="selector" range="{{sportTypes[selectedSportIndex].units}}" range-key="label" value="{{selectedUnitIndex}}" bindchange="onUnitChange">
            <view class="form-picker">
              <text>{{sportTypes[selectedSportIndex].units[selectedUnitIndex].label}}</text>
              <text class="picker-arrow">▼</text>
            </view>
          </picker>
        </view>

        <view class="form-item">
          <text class="form-label">运动数值</text>
          <view class="form-input-wrap">
            <input
              class="form-input"
              type="number"
              value="{{inputValue}}"
              bindinput="onValueInput"
              placeholder="请输入"
            />
          </view>
        </view>
      </view>

      <view class="modal-btns">
        <button class="modal-btn cancel" bindtap="closeShareModal">取消</button>
        <button class="modal-btn confirm" bindtap="shareToWeRun">确认分享</button>
      </view>
    </view>
  </view>
</view>
