<!--pages/index/index.wxml-->
<view class="container">
  <!-- 头部卡片 -->
  <view class="header-card">
    <view class="vip-badge" wx:if="{{isVip}}">
      <text>会员</text>
    </view>
    <view class="user-info">
      <view class="welcome">欢迎使用 AI 刷步助手</view>
      <view class="vip-info" wx:if="{{isVip}}">
        <text>会员有效期：{{vipExpireAt}}</text>
        <text class="remaining">剩余 {{remainingDays}} 天</text>
      </view>
      <view class="vip-info expired" wx:else>
        <text>暂未开通会员</text>
      </view>
    </view>
  </view>

  <!-- 功能卡片 -->
  <view class="feature-card">
    <view class="card-title">功能特点</view>
    <view class="feature-list">
      <view class="feature-item">
        <view class="icon">🚀</view>
        <view class="text">
          <view class="title">无需下载APP</view>
          <view class="desc">微信小程序直接使用</view>
        </view>
      </view>
      <view class="feature-item">
        <view class="icon">⏰</view>
        <view class="text">
          <view class="title">定时自动刷步</view>
          <view class="desc">设置后每天自动执行</view>
        </view>
      </view>
      <view class="feature-item">
        <view class="icon">📈</view>
        <view class="text">
          <view class="title">步数智能递增</view>
          <view class="desc">模拟真实走路节奏</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 开始按钮 -->
  <view class="action-card">
    <button class="start-btn" bindtap="goChat">
      开始刷步
    </button>
    <view class="contact">
      <text>遇到问题？联系客服：</text>
      <text class="qq" bindtap="copyQQ">QQ: 188177020</text>
    </view>
  </view>
</view>
