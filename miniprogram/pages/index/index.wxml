<!--pages/index/index.wxml-->
<view class="page">
  <!-- 渐变头部背景 -->
  <view class="header-bg"></view>

  <!-- 用户欢迎卡片 -->
  <view class="welcome-card">
    <view class="vip-badge" wx:if="{{isVip}}">
      <text class="vip-icon">👑</text>
      <text>会员</text>
    </view>

    <view class="user-section">
      <view class="avatar-wrap">
        <image
          class="user-avatar"
          wx:if="{{displayAvatarUrl}}"
          src="{{displayAvatarUrl}}"
          mode="aspectFill"
          binderror="onAvatarError"
        ></image>
        <view class="user-avatar fallback" wx:else>{{avatarText}}</view>
        <view class="avatar-ring"></view>
      </view>

      <view class="user-info">
        <view class="greeting">{{greeting}}</view>
        <view class="greeting">今天想怎么动一动？</view>
        <view class="username">{{(userProfile && userProfile.nickName) || '微信用户'}}</view>
      </view>
    </view>

    <view class="status-bar">
      <view class="status-item">
        <text class="status-icon">{{isVip ? '✨' : '⏱'}}</text>
        <view class="status-text">
          <text class="status-value">{{isVip ? '会员有效' : '体验中'}}</text>
          <text class="status-label">当前状态</text>
        </view>
      </view>
      <view class="status-divider"></view>
      <view class="status-item">
        <text class="status-icon">📅</text>
        <view class="status-text">
          <text class="status-value">{{remainingDays > 0 ? remainingDays + '天' : '已结束'}}</text>
          <text class="status-label">剩余时间</text>
        </view>
      </view>
    </view>
  </view>

  <view class="profile-guide-card" wx:if="{{showProfileGuide && !hasProfile}}">
    <view class="profile-guide-title">资料补充后可更快识别你的记录</view>
    <view class="profile-guide-desc">补充头像和昵称后，首页展示会更完整，也方便后续同步查看。</view>
    <view class="profile-guide-actions">
      <button class="profile-guide-btn ghost" bindtap="closeProfileGuide">稍后再说</button>
      <button class="profile-guide-btn primary" bindtap="goMyProfile">去完善</button>
    </view>
  </view>

  <!-- 功能特点 -->
  <view class="section">
    <view class="section-header">
      <view class="section-title">今日记录</view>
      <view class="section-line"></view>
    </view>

    <view class="feature-grid">
      <view class="feature-card">
        <view class="feature-icon">🏃</view>
        <view class="feature-title">轻松打卡</view>
        <view class="feature-desc">随手记下今天动过的每一段节奏</view>
      </view>

      <view class="feature-card">
        <view class="feature-icon">📊</view>
        <view class="feature-title">节奏复盘</view>
        <view class="feature-desc">看看今天比昨天多走了多少、稳了多少</view>
      </view>

      <view class="feature-card">
        <view class="feature-icon">🎯</view>
        <view class="feature-title">目标管理</view>
        <view class="feature-desc">把计划拆成每天都能完成的小目标</view>
      </view>

      <view class="feature-card">
        <view class="feature-icon">💬</view>
        <view class="feature-title">记录分析</view>
        <view class="feature-desc">查看记录变化和常用数据，安排更从容</view>
      </view>
    </view>
  </view>

  <!-- 开始按钮 -->
  <view class="action-section" wx:if="{{!reviewMode}}">
    <button class="start-btn" bindtap="goChat">
      <text class="btn-icon">🚀</text>
      <text>开始今日打卡</text>
    </button>
    <view class="action-tip">今天动一点，也是在认真照顾自己</view>
  </view>
</view>

<!-- 登录弹窗 -->
<view class="login-modal-mask" wx:if="{{showLoginModal}}" catchtouchmove="preventTouchMove">
  <view class="login-modal">
    <view class="login-modal-header">
      <text class="login-modal-icon">👋</text>
      <text class="login-modal-title">欢迎回来，开始今天的轻运动</text>
      <text class="login-modal-desc">登录后可同步保存记录，并查看每一次小进步</text>
    </view>

    <view class="login-modal-body">
      <view class="login-benefit" wx:for="{{loginBenefits}}" wx:key="icon">
        <text class="login-benefit-icon">{{item.icon}}</text>
        <text class="login-benefit-text">{{item.text}}</text>
      </view>
    </view>

    <view class="login-modal-footer">
      <button class="login-btn-primary" bindtap="handleLogin" loading="{{loginLoading}}">
        <text wx:if="{{!loginLoading}}">微信一键登录</text>
      </button>
      <button class="login-btn-skip" bindtap="skipLogin">稍后再说</button>
    </view>
  </view>
</view>
