<!--pages/index/index.wxml-->
<view class="container">
  <!-- 头部卡片 -->
  <view class="header-card">
    <view class="vip-badge" wx:if="{{isVip}}">会员</view>
    <view class="profile-row">
      <image class="profile-avatar" wx:if="{{userProfile && userProfile.avatarUrl}}" src="{{userProfile.avatarUrl}}" mode="aspectFill"></image>
      <view class="profile-avatar profile-avatar-fallback" wx:else>{{avatarText}}</view>
      <view class="user-info">
        <view class="welcome">你好，{{(userProfile && userProfile.nickName) || '微信用户'}}</view>
        <view class="subtitle">欢迎使用运动记录</view>
        <view class="vip-info" wx:if="{{isVip}}">
          <text>会员有效期：{{vipExpireAt}}</text>
          <text class="remaining">剩余 {{remainingDays}} 天</text>
        </view>
        <view class="vip-info expired" wx:else>体验用户</view>
      </view>
    </view>
  </view>

  <!-- 看广告领会员（会员过期时显示）- 暂时隐藏 -->
  <!-- <view class="ad-card" wx:if="{{!isVip}}">
    <view class="ad-left">
      <view class="ad-icon">🎁</view>
      <view class="ad-content">
        <view class="ad-title">看广告领会员</view>
        <view class="ad-desc">每次观看获得 {{adRewardDays}} 天会员 · 今日已看 {{adDailyCount}}/{{adDailyLimit}} 次</view>
      </view>
    </view>
    <button class="ad-btn {{adCanWatch ? '' : 'disabled'}}" bindtap="watchAd" disabled="{{!adCanWatch}}">
      {{adCanWatch ? '立即观看' : '已达上限'}}
    </button>
  </view> -->

  <!-- 功能卡片 -->
  <view class="feature-card">
    <view class="card-title">功能特点</view>
    <view class="feature-list">
      <view class="feature-item">
        <view class="icon">🏃</view>
        <view class="text">
          <view class="title">运动追踪</view>
          <view class="desc">记录每日运动数据</view>
        </view>
      </view>
      <view class="feature-item">
        <view class="icon">📊</view>
        <view class="text">
          <view class="title">数据分析</view>
          <view class="desc">智能分析运动效果</view>
        </view>
      </view>
      <view class="feature-item">
        <view class="icon">🎯</view>
        <view class="text">
          <view class="title">目标设定</view>
          <view class="desc">制定个性化运动计划</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 开始按钮 -->
  <view class="action-card" wx:if="{{!reviewMode}}">
    <button class="start-btn" bindtap="goChat">开始记录</button>
  </view>
</view>
