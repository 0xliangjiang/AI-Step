/* pages/index/index.wxss */

/* ========== 页面基础 ========== */
.page {
  min-height: 100vh;
  padding: 0 24rpx 40rpx;
  background: linear-gradient(180deg, #f0f4ff 0%, #f8fafc 30%, #f5f7fb 100%);
  box-sizing: border-box;
  position: relative;
}

/* 渐变头部背景 */
.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 320rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%);
  border-radius: 0 0 60rpx 60rpx;
  z-index: 0;
}

.header-bg::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.08'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
  border-radius: 0 0 60rpx 60rpx;
}

/* ========== 欢迎卡片 ========== */
.welcome-card {
  position: relative;
  z-index: 1;
  margin-top: 60rpx;
  padding: 40rpx 32rpx 32rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 32rpx;
  box-shadow:
    0 8rpx 32rpx rgba(102, 126, 234, 0.15),
    0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  backdrop-filter: blur(20rpx);
}

.vip-badge {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 20rpx;
  background: linear-gradient(135deg, #ffd700 0%, #ffb347 100%);
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: #7c5800;
  box-shadow: 0 4rpx 12rpx rgba(255, 183, 71, 0.4);
}

.vip-icon {
  font-size: 20rpx;
}

.user-section {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar-wrap {
  position: relative;
  flex-shrink: 0;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  position: relative;
  z-index: 2;
}

.user-avatar.fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  font-size: 48rpx;
  font-weight: 700;
}

.avatar-ring {
  position: absolute;
  top: -6rpx;
  left: -6rpx;
  right: -6rpx;
  bottom: -6rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.8);
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.3);
  z-index: 1;
}

.user-info {
  flex: 1;
  min-width: 0;
}

.greeting {
  color: #6b7280;
  font-size: 26rpx;
  margin-bottom: 6rpx;
}

.username {
  color: #1a1a2e;
  font-size: 40rpx;
  font-weight: 700;
  letter-spacing: 0.5rpx;
}

/* 状态栏 */
.status-bar {
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(102, 126, 234, 0.1);
  display: flex;
  align-items: center;
}

.status-item {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.status-icon {
  font-size: 32rpx;
}

.status-text {
  display: flex;
  flex-direction: column;
}

.status-value {
  color: #1a1a2e;
  font-size: 28rpx;
  font-weight: 700;
}

.status-label {
  color: #9ca3af;
  font-size: 22rpx;
  margin-top: 2rpx;
}

.status-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(102, 126, 234, 0.1);
  margin: 0 20rpx;
}

/* ========== Section ========== */
.section {
  margin-top: 32rpx;
}

.section-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
  padding: 0 8rpx;
}

.section-title {
  color: #374151;
  font-size: 28rpx;
  font-weight: 700;
  white-space: nowrap;
}

.section-line {
  flex: 1;
  height: 1rpx;
  background: linear-gradient(90deg, rgba(102, 126, 234, 0.3) 0%, transparent 100%);
}

/* ========== 功能网格 ========== */
.feature-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.feature-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow:
    0 4rpx 20rpx rgba(102, 126, 234, 0.08),
    0 1rpx 4rpx rgba(0, 0, 0, 0.02);
  transition: transform 0.2s ease;
}

.feature-card:active {
  transform: scale(0.98);
}

.feature-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #f0f4ff 0%, #e8ecff 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-bottom: 16rpx;
}

.feature-title {
  color: #1a1a2e;
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.feature-desc {
  color: #9ca3af;
  font-size: 24rpx;
}

/* ========== 开始按钮 ========== */
.action-section {
  margin-top: 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.start-btn {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 700;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.4);
  transition: all 0.2s ease;
}

.start-btn::after {
  border: none;
}

.start-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.4);
}

.btn-icon {
  font-size: 36rpx;
}

.action-tip {
  margin-top: 16rpx;
  color: #9ca3af;
  font-size: 24rpx;
}

/* ========== 登录弹窗 ========== */
.login-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.login-modal {
  width: 600rpx;
  background: #ffffff;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.2);
}

.login-modal-header {
  padding: 48rpx 32rpx 32rpx;
  text-align: center;
  background: linear-gradient(135deg, #f0f4ff 0%, #e8ecff 100%);
}

.login-modal-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 16rpx;
}

.login-modal-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 8rpx;
}

.login-modal-desc {
  display: block;
  font-size: 26rpx;
  color: #6b7280;
}

.login-modal-body {
  padding: 32rpx;
}

.login-benefit {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.login-benefit:last-child {
  border-bottom: none;
}

.login-benefit-icon {
  font-size: 36rpx;
}

.login-benefit-text {
  font-size: 28rpx;
  color: #374151;
}

.login-modal-footer {
  padding: 0 32rpx 40rpx;
}

.login-btn-primary {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.3);
}

.login-btn-primary::after {
  border: none;
}

.login-btn-primary:active {
  transform: scale(0.98);
}

.login-btn-skip {
  width: 100%;
  height: 80rpx;
  background: transparent;
  color: #9ca3af;
  font-size: 28rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-btn-skip::after {
  border: none;
}
