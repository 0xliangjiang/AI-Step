/* pages/index/index.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #667eea 0%, #764ba2 100%);
  padding: 60rpx 40rpx;
  box-sizing: border-box;
}

/* 头部卡片 */
.header-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  margin-bottom: 40rpx;
  position: relative;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.vip-badge {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  background: linear-gradient(135deg, #ffd700, #ffaa00);
  color: #fff;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.user-info .welcome {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 16rpx;
}

.vip-info {
  font-size: 26rpx;
  color: #666;
}

.vip-info .remaining {
  color: #667eea;
  font-weight: 600;
  margin-left: 16rpx;
}

.vip-info.expired {
  color: #999;
}

/* 功能卡片 */
.feature-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 32rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 32rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #667eea;
}

.feature-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 20rpx;
}

.feature-item .icon {
  font-size: 40rpx;
  width: 80rpx;
  height: 80rpx;
  background: #fff;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.feature-item .text .title {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
}

.feature-item .text .desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

/* 底部操作 */
.action-card {
  text-align: center;
  padding: 40rpx 0;
}

.start-btn {
  background: #fff;
  color: #667eea;
  font-size: 34rpx;
  font-weight: 700;
  padding: 32rpx 100rpx;
  border-radius: 50rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  white-space: nowrap;
}

.start-btn:active {
  transform: scale(0.98);
}

/* 广告卡片 */
.ad-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 32rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.ad-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
}

.ad-icon {
  font-size: 40rpx;
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #fff9e6, #ffe58f);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ad-content {
  flex: 1;
}

.ad-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #d48806;
  margin-bottom: 6rpx;
}

.ad-desc {
  font-size: 22rpx;
  color: #fa8c16;
}

.ad-btn {
  background: linear-gradient(135deg, #ffa940, #fa8c16);
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  padding: 16rpx 24rpx;
  border-radius: 30rpx;
  flex-shrink: 0;
}

.ad-btn.disabled {
  background: #ccc;
  color: #fff;
}
