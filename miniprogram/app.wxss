/* app.wxss - 全局样式 */
page {
  --brand-sun: #FF8A3D;
  --brand-sun-deep: #F06B1F;
  --brand-lake: #39B8FF;
  --brand-lake-soft: #BCEEFF;
  --brand-ink: #16324F;
  --brand-mint: #28C69A;
  --page-cream: #FFF8F0;
  --page-mist: #FFFDF8;
  --card-bg: rgba(255, 255, 255, 0.92);
  --line-soft: rgba(22, 50, 79, 0.08);
  background: linear-gradient(180deg, #FFF8F0 0%, #FFFDF8 58%, #F4FBFF 100%);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  color: #16324F;
}

/* 隐藏滚动条 */
::-webkit-scrollbar {
  display: none;
}

/* 按钮重置 */
button {
  margin: 0;
  padding: 0;
  background: transparent;
  border: none;
  line-height: inherit;
}

button::after {
  display: none;
}
