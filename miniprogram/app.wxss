/* app.wxss - 全局样式 */
page {
  --primary-color: #667eea;
  --primary-dark: #764ba2;
  background: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  color: #333;
}

/* 隐藏滚动条 */
::-webkit-scrollbar {
  display: none;
}

/* 按钮重置 */
button {
  margin: 0;
  padding: 0;
  background: transparent;
  border: none;
  line-height: inherit;
}

button::after {
  display: none;
}
