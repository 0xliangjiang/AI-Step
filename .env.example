# =========================
# 基础运行配置
# =========================

# MySQL 配置（必填）
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=replace_with_mysql_password
MYSQL_DATABASE=ai_step

# 调试与超时
APP_DEBUG=false
REQUEST_TIMEOUT=30

# 管理后台配置
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace_with_admin_password
ADMIN_SECRET_KEY=replace_with_long_random_secret

# =========================
# AI 配置（二选一）
# =========================

AI_PROVIDER=minimax

# MiniMax（AI_PROVIDER=minimax 时必填）
MINIMAX_API_KEY=replace_with_minimax_api_key
MINIMAX_GROUP_ID=replace_with_minimax_group_id

# GLM（AI_PROVIDER=glm 时必填）
# GLM_API_KEY=replace_with_glm_api_key

# =========================
# 业务配置
# =========================

# 第三方绑定/刷步接口 key
NANRUN_API_KEY=replace_with_nanrun_api_key

# 新用户赠送天数 / 广告奖励
FREE_DAYS=3
AD_REWARD_DAYS=1
AD_DAILY_LIMIT=3

# 验证码与缓存
CAPTCHA_PENDING_EXPIRE=300

# 刷步范围通常无需修改
# MIN_STEPS=1
# MAX_STEPS=98800

# =========================
# 微信小程序 / 微信支付
# =========================

# 小程序登录
WX_APPID=replace_with_miniprogram_appid
WX_SECRET=replace_with_miniprogram_secret

# 微信支付
WX_MCH_ID=replace_with_wechat_mch_id
WX_API_KEY=replace_with_wechat_pay_v2_key
WX_API_V3_KEY=replace_with_wechat_pay_v3_key
WX_NOTIFY_URL=https://api.example.com/api/pay/notify

# 证书路径（容器内路径或宿主机挂载后的路径）
WX_CERT_PATH=/app/certs/apiclient_cert.pem
WX_KEY_PATH=/app/certs/apiclient_key.pem

# =========================
# Zepp / 代理配置
# =========================

# 是否启用代理能力
USE_PROXY=true

# 代理池接口
PROXY_API_URL=https://api.nstproxy.com/api/v1/generate/apiproxies?count=1&country=ANY&protocol=http&sessionDuration=10&channelId=replace_with_channel_id&format=1&fType=1&lfType=1&token=replace_with_token

# true: Zepp 登录 + token 刷步
# false: 注册使用代理，绑定/刷步走第三方接口
USE_PROXY_MODE=true

# Zepp 加密参数（通常保持默认）
ZEPP_AES_KEY=xeNtBVqzDc6tuNTh
ZEPP_AES_IV=MAAAYAAAAAAAAABg
