# 刷步微服务环境变量示例
# 复制此文件为 .env 并填入真实值

# 服务安全密钥（与国外服务器的 STEP_SERVICE_KEY 保持一致）
STEP_SERVICE_KEY=change-me-please

# 服务监听端口
SERVICE_PORT=8001

# 代理配置（用于登录 Zepp，需国内代理）
PROXY_API_URL=https://api.nstproxy.com/...
USE_PROXY=true

# Zepp 加密密钥（与主服务保持一致）
ZEPP_AES_KEY=xeNtBVqzDc6tuNTh
ZEPP_AES_IV=MAAAYAAAAAAAAABg

# nan.run 绑定 API 密钥
NANRUN_API_KEY=your-nanrun-api-key

# 调试模式
APP_DEBUG=false

# 验证码 OCR 重试次数
CAPTCHA_RETRY_TIMES=5
